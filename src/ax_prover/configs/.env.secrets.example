# LLM API Keys (add the ones you plan to use)
# ============================================
# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# Web Search
# ============================================
# Tavily - Web search API for LLMs
# Get your API key from: https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# LangSmith (optional, for tracing and monitoring)
# ============================================
LANGSMITH_TRACING_V2=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=ax-prover
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # For self-hosted
