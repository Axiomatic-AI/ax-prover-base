# =============================================================================
# GCP Project & Region
# =============================================================================
export GCP_PROJECT_ID="axiomatic-xxxx"
export GCP_REGION="europe-west4"

# =============================================================================
# Storage Buckets
# =============================================================================
export GCP_CONFIG_BUCKET="ax-experiment-configs"
export GCP_ARTIFACT_BUCKET="ax-experiment-artifacts"

# =============================================================================
# Artifact Registry (Docker images)
# =============================================================================
export AR_REPO="ax-containers"
export AR_REGION="europe-west1"  # Regional endpoint, e.g. europe-west1, us-central1

# Image names
export BASE_IMAGE_NAME="leanbench-base"
export RUNNER_IMAGE_NAME="ax-prover-runner"
export DEFAULT_RUNNER_TAG="latest"

# =============================================================================
# Service Account (for Batch jobs)
# =============================================================================
export BATCH_RUNNER_SA_NAME="ax-batch-runner"
export BATCH_RUNNER_SA_EMAIL="${BATCH_RUNNER_SA_NAME}@${GCP_PROJECT_ID}.iam.gserviceaccount.com"

# =============================================================================
# Secrets
# =============================================================================
export ENV_SECRETS_SECRET_NAME="AX_ENV_SECRETS"

# =============================================================================
# Lean Benchmarks Repository (for base image build)
# =============================================================================
export LEANBENCH_REPO_SSH="git@github.com:AxiomaticX/lean_benchmarks.git"

# =============================================================================
# Optional: LeanSearch Cloud Run service
# =============================================================================
# If your LeanSearch is Cloud Run, grant run.invoker to the batch SA
export LEANSEARCH_SERVICE=""        # e.g. "leansearch"
export LEANSEARCH_SERVICE_REGION="" # e.g. "europe-west4"

# =============================================================================
# Optional: Job naming prefix
# =============================================================================
export PREFIX="ax"

# =============================================================================
# Setup instructions for deploy key (run once, from gcp/ directory):
#   ssh-keygen -t ed25519 -C "cloudbuild-leanbench" -f /tmp/leanbench_deploy_key -N ""
#   # Add /tmp/leanbench_deploy_key.pub as deploy key in GitHub repo settings
#   cat /tmp/leanbench_deploy_key | make put-secret NAME=LEANBENCH_DEPLOY_KEY
# =============================================================================
